# OpenAI API key — required
OPENAI_API_KEY=sk-...

# LangSmith API key — required for tracing
LANGCHAIN_API_KEY=ls__...

# LangSmith project name — optional, defaults to "store-assistant"
LANGCHAIN_PROJECT=store-assistant

# LangSmith tracing toggle — optional, defaults to "true"
LANGCHAIN_TRACING_V2=true

# Secret passphrase to gate store lookups — required
STORE_LOOKUP_PASSPHRASE=your-secret-passphrase

# SQLite database file path — optional, defaults to "store_assistant.db"
STORE_DB_PATH=store_assistant.db
